    "check": "npm run typecheck && npm test && npm run deploy:dry-run"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "dejavu-fonts-ttf": "^2.37.3",
    "hono": "^4.12.31",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "typescript": "^7.0.2",
    "wrangler": "^4.112.0"
  }
}
